ex="16" value="39"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Product" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Product_Analysis" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/><column index="2" value="85"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Sales" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/><column index="2" value="132"/><column index="3" value="78"/><column index="4" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Segment" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="132"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Yearly_Analysis" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="39"/><column index="2" value="93"/><column index="3" value="93"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT *FROM Financials;
SELECT Country,Product,Sales 
FROM Financials;
SELECT *FROM Financials
WHERE Country = &quot;Canada&quot;;
SELECT  *FROM Financials
WHERE Product =&quot;Paseo&quot; AND Sales &lt; 10000;
SELECT SUM(Sales) As Total_Revenue	
FROM Financials;
SELECT Country, SUM(Sales)
FROM Financials
GROUP BY Country;
SELECT Country, SUM(Sales) Revenue
FROM Financials
GROUP BY Country
ORDER BY Revenue DESC;
SELECT &quot;Discount Band&quot;, AVG(Profit) AS Avg_Profit
FROM Financials
GROUP BY &quot;Discount Band&quot;;
SELECT Product, SUM(Profit) AS Profit
FROM Financials
GROUP BY Product
ORDER BY Product DESC;
SELECT Country, SUM(Sales) AS Total_Sales
FROM Financials
GROUP BY Country
ORDER BY Total_Sales DESC;
SELECT &quot;Discount Band&quot;, 
       SUM(Sales) AS Total_Sales,
       SUM(Profit) AS Total_Profit
FROM Financials
GROUP BY &quot;Discount Band&quot;
ORDER BY Total_Profit DESC;
SELECT Segment, SUM(Profit) AS Total_Profit
FROM Financials
GROUP BY Segment
ORDER BY Total_Profit DESC;
SELECT strftime('%Y-%m', Date) AS Month,
       SUM(Sales) AS Monthly_Sales
FROM Financials
GROUP BY Month
ORDER BY Month;
SELECT Product,
       SUM(Profit) * 1.0 / SUM(Sales) AS Profit_Margin
FROM Financials
GROUP BY Product
ORDER BY Profit_Margin DESC;
SELECT *FROM Financials
WHERE Sales &gt; 10000;
SELECT Product, 
       Segment, 
     SUM(Sales) AS Total_Sales,
     SUM(Profit) AS Total_Profit
FROM Financials
WHERE Country = 'France'
GROUP BY Product, Segment
ORDER BY Total_Profit DESC;
SELECT 
     Substr ( Date, -4) AS Year,
	 Product,
	 SUM(Sales) AS Total_Sales,
	 SUM(Profit) AS Total_Profit
FROM Financials
GROUP BY Product, Year;
SELECT *
FROM (
    SELECT
     Substr ( Date, -4) AS Year,
	 Product,
	 SUM(Sales) AS Total_Sales,
	 RANK() OVER (
	      PARTITION BY Substr(Date, -4)
	      ORDER  BY SUM(Sales)DESC
	 ) AS rank
FROM Financials
GROUP BY Year, Product
)
WHERE RANK = 1;
SELECT *
FROM (
    SELECT
	Substr(Date, -4) AS Year,
	Product,
	Segment,
	SUM(Sales) AS Total_Sales,
	RANK() OVER (
          PARTITION BY substr(Date, -4) 
          ORDER BY SUM(Sales) ASC
    )AS rank
FROM Financials
GROUP BY Year, Product, Segment
)
WHERE RANK =1;
SELECT 
    substr(Date, -4) AS Year,
    Product,
    SUM(Sales) AS Total_Sales,
    SUM(COGS) AS Total_Cost,
    SUM(Sales - COGS) AS EBITDA
FROM Financials
GROUP BY Year, Product
ORDER BY EBITDA DESC;
SELECT 
    Product,
    SUM(Sales - COGS) * 1.0 / SUM(Sales) AS EBITDA_Margin
FROM Financials
GROUP BY Product
ORDER BY EBITDA_Margin DESC;
SELECT Segment,
SUM(Sales - COGS) AS EBITDA
FROM Financials
GROUP BY Segment
ORDER BY EBITDA DESC;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
